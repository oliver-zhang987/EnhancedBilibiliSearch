# --- AIVideoSummary backend (reused for per-video summaries over HTTP) ---
EBS_BACKEND_URL=http://127.0.0.1:8010
EBS_BACKEND_API_KEY=

# --- Synthesis LLM (the single "stronger" call) ---
EBS_SYNTH_MODEL=deepseek-v4-pro
EBS_LLM_API_KEY=
EBS_LLM_BASE_URL=https://api.deepseek.com

# --- Bilibili search ---
EBS_COOKIES_FILE=/app/cookies.txt
EBS_SEARCH_ORDER=totalrank
EBS_DURATION_FILTER=2          # 0 all, 1 <10m, 2 10-30m, 3 30-60m, 4 >60m
EBS_TIDS=0

# --- Selection / cost gates ---
EBS_MAX_VIDEOS=6
EBS_CANDIDATE_PAGES=2
EBS_ALLOW_ASR=false
EBS_MIN_PLAY=1000
EBS_MIN_DURATION_SEC=120
EBS_MAX_DURATION_SEC=3600       # drop multi-hour course compilations
EBS_ALLOW_LLM_RERANK=false      # optional cheap-LLM rerank of candidates
EBS_RERANK_MODEL=deepseek-v4-flash

# --- Query strategy (duration filter above is the biggest free win) ---
EBS_QUERY_SUGGEST=false         # B站 suggest to normalize the query (cheap)
EBS_QUERY_EXPAND=false          # LLM query expansion (best precision upgrade)
EBS_QUERY_EXPAND_PAGES=1
EBS_QUERY_MULTI_ORDER=false     # also order=click (off: drifts off-topic)
